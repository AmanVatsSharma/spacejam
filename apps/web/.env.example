# GraphQL endpoint of the NestJS backend
NEXT_PUBLIC_GRAPHQL_HTTP_URL=http://localhost:3000/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:3000/graphql

# Optional override. The "Dev login" button on the sign-in page is shown
# automatically when the page is served from localhost (or any *.localhost
# host). Set this to "true" to force-enable it on a non-localhost host
# (e.g. a tunnel or a custom dev domain). NEVER set this in production.
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false