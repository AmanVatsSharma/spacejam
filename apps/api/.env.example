# Environment Configuration for SpaceJam API

# Node.js
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://spacejam:spacejam@localhost:5432/spacejam
DATABASE_SSL_MODE=require
DATABASE_CONNECTION_POOL=10
DATABASE_MIGRATION_AUTO_RUN=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_CLUSTER_MODE=false
REDIS_CONNECTION_POOL=10

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-secret-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS Settings
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@spacejam.com

# Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# External APIs
GOOGLE_MAPS_API_KEY=
SENDGRID_API_KEY=

# Monitoring
SENTRY_DSN=
SENTRY_ENV=production

# Security
BCRYPT_ROUNDS=10
SESSION_TIMEOUT=3600
CSRF_ENABLED=true

# Database Replication (Optional)
DATABASE_READER_URL=
DATABASE_STANDBY_URL=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=

# Cache Configuration
CACHE_DEFAULT_TTL=3600
CACHE_LONG_TTL=86400