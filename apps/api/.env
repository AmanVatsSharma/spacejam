# Environment Configuration for SpaceJam API

# Node.js
NODE_ENV=development
PORT=3100

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=spacejam
DATABASE_PASSWORD=spacejam
DATABASE_NAME=spacejam
DATABASE_SSL=false

# Redis (optional - uses in-memory fallback if not available)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production-12345
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://spacejam:spacejam@localhost:5432/spacejam
