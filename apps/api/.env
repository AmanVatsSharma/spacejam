# SpaceJam Development Environment
# Copy this file to .env and fill in actual values

# Node.js
NODE_ENV=development
PORT=3001

# Database (update with your credentials)
DATABASE_URL=postgresql://spacejam:spacejam@localhost:5432/spacejam

# Redis (update with your credentials)
REDIS_URL=redis://localhost:6379

# Authentication (generate secure secrets for production)
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000