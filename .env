# Development environment variables
NODE_ENV=development

# Database - SQLite for local development (no server needed)
DATABASE_URL=file:./dev.sqlite
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=spacejam
DATABASE_PASSWORD=spacejam
DATABASE_NAME=spacejam
DATABASE_SSL=false

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production-12345
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (optional - uses in-memory fallback if not available)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (dev mode logs to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@spacejam.local

# App
PORT=4000
FRONTEND_URL=http://localhost:3001
